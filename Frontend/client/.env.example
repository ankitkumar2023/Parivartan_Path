# ================================================
# Parivartan Path - Frontend Environment Variables
# ================================================
# Copy this to .env.local and fill in your values
# IMPORTANT: Never commit .env.local to Git

# ==================== 
# API Configuration
# ====================
# Backend API URL (use http://localhost:5000 for development)
VITE_API_URL=https://parivartan-path.onrender.com

VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# ==================== 
# Notes
# ====================
# All VITE_ prefixed variables are accessible in the frontend
# Non-VITE_ variables will NOT be available in the frontend
# Always prefix with VITE_ for frontend environment variables

