# ================================================
# Parivartan Path - Frontend Environment Variables
# ================================================
# Copy this to .env.local and fill in your values
# IMPORTANT: Never commit .env.local to Git

# ==================== 
# API Configuration
# ====================
# Backend API URL (use http://localhost:5000 for development)
VITE_API_URL=https://parivartan-path.onrender.com

# ==================== 
# EmailJS Configuration
# ====================
# Sign up at https://www.emailjs.com/ to get these values
# These are REQUIRED for email functionality to work

# EmailJS Service ID (from Email Services section)
# Example: service_abc123def456
VITE_EMAILJS_SERVICE_ID=service_xxxxx

# EmailJS Template IDs (from Email Templates section)
# Example: template_abc123def456
VITE_EMAILJS_CONTACT_TEMPLATE_ID=template_contact_form
VITE_EMAILJS_BOOKING_TEMPLATE_ID=template_booking_notification

# EmailJS Public Key (from Account settings)
# This is safe to expose (meant for client-side use)
# Example: abc123def456ghi789jkl012mno345
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# ==================== 
# Notes
# ====================
# All VITE_ prefixed variables are accessible in the frontend
# Non-VITE_ variables will NOT be available in the frontend
# Always prefix with VITE_ for frontend environment variables

