# ================================================
# Parivartan Path - Backend Environment Variables
# ================================================
# Copy this to .env and fill in your values
# IMPORTANT: Never commit .env to Git

# ==================== 
# Server Configuration
# ====================
# Port to run the server on
PORT=5000

# Environment: development, production, or test
NODE_ENV=development

# ==================== 
# Database Configuration
# ====================
# MongoDB connection URI
# Development: mongodb://localhost:27017/parivartan
# Production: use cloud MongoDB (Atlas, etc.)
MONGO_URI=mongodb://localhost:27017/parivartan

# ==================== 
# Authentication (JWT)
# ====================
# Secret key for signing JWT tokens
# Generate a secure random string for production
# Use at least 32 characters for security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_characters
JWT_EXPIRES_IN=7d

# ==================== 
# CORS Configuration
# ====================
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ==================== 
# Email Configuration (Optional)
# ====================
# SMTP configuration for backend email (if sending from backend)
# These are optional - frontend uses EmailJS for emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ==================== 
# Admin Account Setup
# ====================
# Used by setupAdmin.js script
ADMIN_EMAIL=admin@parivartan.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

# ==================== 
# Logging
# ====================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ==================== 
# Security
# ====================
# Rate limiting threshold
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== 
# Notes
# ====================
# All environment variables are read by the backend
# Frontend CANNOT access backend environment variables
# For frontend env vars, use VITE_ prefix in Frontend/client/.env.local
# Backend runs on the server, frontend runs in browser
