# ================================================
# Parivartan Path - Backend Environment Variables
# ================================================
# Copy this to .env and fill in your values
# IMPORTANT: Never commit .env to Git

# ==================== 
# Server Configuration
# ====================
# Port to run the server on
PORT=5000

# Environment: development, production, or test
NODE_ENV=development

# ==================== 
# Database Configuration
# ====================
# MongoDB connection URI
# Development: mongodb://localhost:27017/parivartan
# Production: use cloud MongoDB (Atlas, etc.)
MONGO_URI=mongodb://localhost:27017/parivartan

# ==================== 
# Authentication (JWT)
# ====================
# Secret key for signing JWT tokens
# Generate a secure random string for production
# Use at least 32 characters for security
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars
JWT_EXPIRES_IN=7d

# ==================== 
# CORS Configuration
# ====================
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com

# ==================== 
# SMTP Configuration (Email System)
# ====================
# Used for sending confirmation and notification emails
# Recommended: Use Gmail with App Password

# SMTP Server Host
SMTP_HOST=smtp.gmail.com

# SMTP Server Port
# 465 for SSL, 587 for TLS
SMTP_PORT=465

# Email address for sending emails
# Example: your-email@gmail.com
SMTP_USER=your-email@gmail.com

# App-specific password (NOT your Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# 1. Enable 2-Factor Authentication on Gmail
# 2. Generate a 16-character App Password
# 3. Paste the password here (without spaces)
SMTP_PASS=your-16-char-app-password-here

# Admin email to receive notifications
# Notifications for new contact forms and bookings go here
ADMIN_EMAIL=admin@parivartan-path.com

# ==================== 
# Admin Account Setup
# ====================
# Used by setupAdmin.js script
ADMIN_EMAIL=admin@parivartan.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

# ==================== 
# Logging
# ====================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ==================== 
# Security
# ====================
# Rate limiting threshold
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== 
# Notes
# ====================
# All environment variables are read by the backend
# Frontend CANNOT access backend environment variables
# For frontend env vars, use VITE_ prefix in Frontend/client/.env.local
# Backend runs on the server, frontend runs in browser
